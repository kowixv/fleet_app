# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# fal.ai (Telegram load parsing — vision + text via your fal key)
FAL_KEY=your-fal-key
# Vision/LLM model routed through fal's OpenRouter endpoint (cheap default)
AI_MODEL=google/gemini-2.5-flash

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
# Secret path token to protect the webhook URL
TELEGRAM_WEBHOOK_SECRET=some-long-random-string

# Cron protection (Vercel Cron sends this as Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=another-long-random-string

# App base URL (used for absolute links in Telegram messages)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Tracking Module ──────────────────────────────────────────────────────────
# Google Routes API key — used only when admin clicks "Refresh ETA"
# Enable: Routes API in Google Cloud Console
# Free tier: $200/month credit (~20,000 ETA requests) — sufficient for most fleets
GOOGLE_ROUTES_API_KEY=

